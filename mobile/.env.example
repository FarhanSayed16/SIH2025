# Flutter Mobile App Environment Variables

# Backend API Base URL (without /api suffix)
# Default: http://localhost:3000
# For port forwarding: http://10.0.2.2:3000 (Android Emulator)
# For physical device: http://YOUR_COMPUTER_IP:3000
BASE_URL=http://localhost:3000

# Socket.io Server URL (without /api suffix)
# Should match BASE_URL unless using different port
SOCKET_URL=http://localhost:3000

# API Version
# Default: v1
API_VERSION=v1

# Environment (development/production)
ENVIRONMENT=development

# Gemini API Key for AI features
# Get your key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
